# =============================================================================
# Vectora Inbox V1 — Variables d'environnement
# =============================================================================
#
# 📋 INSTRUCTIONS POUR FRANK
#
# 1. Copie ce fichier en `.env` (sans le .example) :
#       cp .env.example .env
#
# 2. Édite `.env` et remplace les valeurs par tes vraies clés.
#    NE COMMIT JAMAIS le fichier `.env` (il est gitignored).
#
# 3. Pour créer une clé Anthropic :
#       https://console.anthropic.com/settings/keys
#    → "Create Key" → copie la clé (format sk-ant-xxxxxxxx...)
#
# Ce fichier `.env.example` reste commité comme template, sans valeurs réelles.
# Quand on ajoute une nouvelle variable d'environnement au moteur,
# on met à jour ce template dans le même commit.
# =============================================================================


# -----------------------------------------------------------------------------
# Anthropic API — REQUIS pour la normalisation
# -----------------------------------------------------------------------------

# Ta clé API Anthropic (format sk-ant-...)
# Obligatoire dès le Niveau 1 (Fondations)
ANTHROPIC_API_KEY=sk-ant-replace-me-with-your-real-key

# Modèle Claude à utiliser pour la normalisation
# Défaut recommandé : claude-sonnet-4-x (bon compromis qualité/coût)
# Alternative pour économiser : claude-haiku-4-x (moins cher, plus rapide, qualité un peu moindre)
ANTHROPIC_MODEL=claude-sonnet-4-x

# Tokens max par réponse (limite la taille de la sortie LLM)
# 4096 suffit pour un summary + entités + event de notre prompt generic_normalization
ANTHROPIC_MAX_TOKENS=4096


# -----------------------------------------------------------------------------
# Configuration runtime — optionnel (a des valeurs par défaut sensées)
# -----------------------------------------------------------------------------

# Niveau de log : DEBUG | INFO | WARNING | ERROR
# DEBUG = très verbeux (utile pour debug)
# INFO = défaut, lisible au quotidien
# WARNING = uniquement les anomalies
LOG_LEVEL=INFO

# Timeout en secondes pour les appels HTTP (fetch des sources)
HTTP_TIMEOUT_SECONDS=30

# Plafond de coût LLM par run de normalisation (en USD)
# Si dépassé, le run s'arrête proprement (sécurité contre runaway)
LLM_COST_CAP_USD_PER_RUN=10.0


# -----------------------------------------------------------------------------
# Chemins (rarement à modifier)
# -----------------------------------------------------------------------------

# Racine du datalake (relative au repo)
DATALAKE_ROOT=data/datalake_v1

# Racine des configs canonical
CANONICAL_ROOT=canonical

# Racine des configs client
CLIENTS_ROOT=config/clients
