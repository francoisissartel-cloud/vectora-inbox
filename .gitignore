# =====================================================================
# .gitignore — Vectora Inbox V1
# =====================================================================
# Voir docs/architecture/datalake_v1_design.md §3 pour le contexte data/.
# =====================================================================

# ---------------------------------------------------------------------
# 1. Données produites au runtime (le datalake)
# ---------------------------------------------------------------------
# Tout sous data/ est ignoré SAUF les .gitkeep qui matérialisent
# l'arborescence cible dans Git.
data/**
!data/**/
!data/**/.gitkeep

# ---------------------------------------------------------------------
# 2. Secrets
# ---------------------------------------------------------------------
.env
*.env
!.env.example
secrets/

# ---------------------------------------------------------------------
# 3. Python
# ---------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/

# ---------------------------------------------------------------------
# 4. Éditeurs et OS
# ---------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------
# 5. Temporaires
# ---------------------------------------------------------------------
.tmp/
*.swp
*~
